{
  "name": "wasser-ui",
  "version": "0.1.0-alpha.0",
  "private": true,
  "homepage": "https://github.com/sichengchen/water-ui#readme",
  "bugs": {
    "url": "https://github.com/sichengchen/water-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sichengchen/water-ui.git"
  },
  "type": "module",
  "scripts": {
    "check": "vp check",
    "test": "vp run -r test",
    "build": "vp run -r build",
    "ready": "vp check && vp run -r test && vp run -r build",
    "release:check": "vp check && vp test && vp run -r build && vp run -r test && pnpm -r --filter './packages/*' publish --access public --tag alpha --dry-run --no-git-checks",
    "publish:dry-run": "pnpm -r --filter './packages/*' publish --access public --tag alpha --dry-run --no-git-checks",
    "publish:alpha": "pnpm -r --filter './packages/*' publish --access public --tag alpha"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "svelte": "catalog:",
    "vite-plus": "catalog:",
    "vue": "catalog:"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "pnpm@11.1.0"
}
